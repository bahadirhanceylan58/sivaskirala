rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- YARDIMCI FONKSİYONLAR ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      // 1. E-posta token kontrolü (hızlı, Firestore okuma gerektirmez)
      // 2. Firestore'da role == 'admin' kontrolü (döküman yoksa güvenli şekilde false döner)
      return request.auth.token.email == 'bahadirhanceylan@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // --- KURALLAR ---

    // 1. KULLANICILAR (Users)
    match /users/{userId} {
      allow read: if true; // Profil bilgilerini herkes görebilir (İlan sahibi adı vs. için)
      allow write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // 2. ÜRÜNLER (Products)
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      // DİKKAT: Burada 'ownerId' kullandık (JavaScript standardı)
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      // Reviews subcollection
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
        allow update: if isSignedIn() && isAdmin();
      }
    }

    // 3. KİRALAMALAR (Bookings)
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.renterId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid || // İlan sahibi de görebilmeli
        isAdmin()
      );
      
      allow create: if isSignedIn();
      
      // Onaylama işlemini ilan sahibi veya admin yapabilir
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin()
      );
    }

    // 4. BİLDİRİMLER (Notifications)
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 5. FAVORİLER (Favorites) — FavoriteButton bileşeni tarafından kullanılır
    match /favorites/{favId} {
      // resource null olabilir (belge yoksa) — bu yüzden sadece isSignedIn() ile kontrol et
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 6. DEĞERLENDİRMELER (Reviews) — Üst seviye koleksiyon
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 7. MESAJLAŞMA (Conversations)
    match /conversations/{convId} {
      allow read, update: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;

      // Mesajlar alt koleksiyonu
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(convId)).data.buyerId == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.sellerId == request.auth.uid
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(convId)).data.buyerId == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.sellerId == request.auth.uid
        ) && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
